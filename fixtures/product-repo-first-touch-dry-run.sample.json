    {
      "cmd": "cat /path/to/kosame-email-reply-bot/README.md",
      "purpose": "README内容確認"
    },
    {
      "cmd": "git -C /path/to/kosame-email-reply-bot log --oneline -5",
      "purpose": "最新5コミット確認 (read-only)"
    },
    {
      "cmd": "git -C /path/to/kosame-email-reply-bot status",
      "purpose": "working tree状態確認 (read-only)"
    },
    {
      "cmd": "find /path/to/kosame-email-reply-bot/docs -name \"*.md\" 2>/dev/null | head -10",
      "purpose": "docs構造確認"
    },
    {
      "cmd": "node --version",
      "purpose": "ランタイムバージョン確認"
    }
  ],
  "allowedFirstTouchAreas": [
