{
  "tool": "secret-key-loader",
  "version": "110.9.0",
  "dryRun": true,
  "realProductActionsExecuted": false,
  "dangerousActionsDenied": true,
  "humanApprovalRequired": true,
  "valueHidden": true,
  "examples": [
    {
      "description": "dryRun mode — no network call, env fallback checked",
      "keyName": "OPENAI_API_KEY",
      "dryRun": true,
      "expected": { "source": "dry_run_or_env_fallback", "valueHidden": true }
    },
    {
      "description": "batch resolve returns per-key source map",
      "keyNames": ["OPENAI_API_KEY", "GEMINI_API_KEY"],
      "expected": { "keyCount": 2, "valueHidden": true }
    }
  ],
  "sourceEnum": ["secret_manager", "env_fallback", "dry_run", "not_found"],
  "safetyPrinciples": [
    "キー値はログに出力しない",
    "dryRun=true では実際のネットワーク呼び出し不可",
    "valueHidden: true を常に返す"
  ]
}
